<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formulario Paciente</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-5">
    <form class="mx-auto p-4" action="{{ path("procesar_formulario") }}" method="post">

        <h2>Paciente Existente</h2>
        <p class="text-black">Si el paciente ya está registrado, ingrese su ID. Si no, deje este campo vacío y registre un nuevo paciente.</p>

        <div class="mb-3">
            <label for="id_paciente" class="form-label">ID Paciente</label>
            <input type="number" id="id_paciente" name="id_paciente" class="form-control">
        </div>

        <h2>Datos del Paciente</h2>
        <div class="form-text text-black mb-3">Ingrese los datos si el paciente es nuevo</div>

        <div class="mb-3">
            <label for="nombre" class="form-label">Nombre</label>
            <input type="text" id="nombre" name="nombre" class="form-control">
        </div>

        <div class="mb-3">
            <label for="fecha_nac" class="form-label">Fecha de nacimiento</label>
            <input type="date" id="fecha_nac" name="fecha_nac" class="form-control">
        </div>

        <div class="mb-3">
            <label for="genero" class="form-label">Género</label>
            <select name="genero" id="genero" class="form-select">
                <option value="">Seleccione</option>
                <option value="M">Masculino</option>
                <option value="F">Femenino</option>
            </select>
        </div>

        <h2>Datos de la Visita</h2>
        <div class="form-text text-black mb-3">Ingrese los datos correctamente</div>

        <div class="mb-3">
            <label for="fecha_visita" class="form-label">Fecha de visita</label>
            <input type="date" id="fecha_visita" name="fecha_visita" class="form-control" required>
        </div>

        <div class="mb-3">
            <label for="nombreMedico" class="form-label">Nombre del médico</label>
            <input type="text" id="nombreMedico" name="nombreMedico" class="form-control" required>
        </div>

        <div class="mb-3">
            <label for="generoMedicamentos" class="form-label">¿Recibe medicamentos?</label>
            <select class="form-select" name="generoMedicamentos" id="generoMedicamentos" required>
                <option value="Si">Sí</option>
                <option value="No">No</option>
            </select>
        </div>

        <div class="d-grid">
            <button type="submit" class="btn btn-primary">Guardar</button>
        </div>

    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>